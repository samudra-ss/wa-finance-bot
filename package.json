{
  "name": "wa-finance-bot",
  "version": "0.1.0",
  "private": true,
  "description": "WhatsApp-first personal finance tracker backend (Indonesian users, IDR) — Express 5 + Prisma/PostgreSQL + Meta WhatsApp Cloud API",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "test": "node --test",
    "webhook:test": "node scripts/send-test-webhook.js"
  },
  "dependencies": {
    "@prisma/client": "^6.10.0",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "prisma": "^6.10.0"
  }
}
