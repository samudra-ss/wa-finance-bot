# ---------- Server ----------
PORT=3000
LOG_LEVEL=info

# ---------- PostgreSQL (Prisma) ----------
# Local dev example. On Railway/Neon paste the connection string they give you.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wa_finance?schema=public"

# ---------- Meta WhatsApp Cloud API ----------
# Graph API version used for every outbound call.
GRAPH_API_VERSION=v23.0

# A random string YOU invent. Must exactly match the "Verify token" field you
# type into the Meta App Dashboard webhook configuration UI.
WA_VERIFY_TOKEN=change-me-verify-token

# App secret: Meta App Dashboard > App settings > Basic > App secret.
# Used to verify the X-Hub-Signature-256 HMAC on every incoming webhook.
WA_APP_SECRET=change-me-app-secret

# Permanent access token. Create a System User in Meta Business Settings,
# assign it the WhatsApp app with whatsapp_business_messaging permission,
# and generate a token that never expires. (The API Setup page token dies in 24h.)
WA_ACCESS_TOKEN=change-me-access-token

# Phone number ID — the numeric ID shown on WhatsApp > API Setup,
# NOT the phone number itself.
WA_PHONE_NUMBER_ID=123456789012345

# ---------- Dashboard (PWA) ----------
# Signs dashboard login tokens (see src/auth.js). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this instantly logs everyone out. Keep it secret — never commit it.
APP_JWT_SECRET=change-me-to-a-random-64-char-hex-string

# The public HTTPS URL of this server, sent to users in the "login" WhatsApp
# reply (e.g. https://keuangan.contoh-domain.com). Local dev: leave as-is.
APP_PUBLIC_URL=http://localhost:3000

# ---------- Behavior ----------
# "true": an unknown WhatsApp number that messages the bot is auto-registered
# with default categories + accounts. Anything else: bot replies "not registered".
ALLOW_AUTO_REGISTER=true

# ---------- Dev helper (scripts/send-test-webhook.js) ----------
# The fake sender wa_id used by the local webhook test script.
TEST_WA_ID=6281234567890
